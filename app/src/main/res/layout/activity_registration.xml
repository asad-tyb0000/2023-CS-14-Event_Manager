<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pageBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/event_banner"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="28dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Registration"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in the details below to register"
                android:textSize="13sp"
                android:textColor="@color/splashTextSub"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Form Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="20dp">

            <!-- Full Name Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. John Doe"
                android:inputType="textPersonName"
                android:textColor="@color/textDark"
                android:textColorHint="@color/textLight"
                android:background="@drawable/input_field_bg"
                android:layout_marginBottom="16dp"
                android:autofillHints="name" />

            <!-- Phone Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. 03001234567"
                android:inputType="phone"
                android:textColor="@color/textDark"
                android:textColorHint="@color/textLight"
                android:background="@drawable/input_field_bg"
                android:layout_marginBottom="16dp"
                android:autofillHints="phone" />

            <!-- Email Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email Address"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. john@email.com"
                android:inputType="textEmailAddress"
                android:textColor="@color/textDark"
                android:textColorHint="@color/textLight"
                android:background="@drawable/input_field_bg"
                android:layout_marginBottom="16dp"
                android:autofillHints="emailAddress" />

            <!-- Event Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Type"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerEventType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_field_bg"
                android:layout_marginBottom="16dp" />

            <!-- Date Picker Row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Date"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/input_field_bg"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnPickDate"
                    android:layout_width="wrap_content"
                    android:layout_height="38dp"
                    android:text="Pick Date"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_primary_rounded"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp" />

                <TextView
                    android:id="@+id/tvDateDisplay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No date selected"
                    android:textSize="14sp"
                    android:textColor="@color/textLight"
                    android:layout_marginStart="14dp" />

            </LinearLayout>

            <!-- Gender Selection -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gender"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="6dp" />

            <RadioGroup
                android:id="@+id/rgGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/input_field_bg"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbMale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Male"
                    android:textColor="@color/textDark"
                    android:layout_weight="1" />

                <RadioButton
                    android:id="@+id/rbFemale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Female"
                    android:textColor="@color/textDark"
                    android:layout_weight="1" />

                <RadioButton
                    android:id="@+id/rbOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Other"
                    android:textColor="@color/textDark"
                    android:layout_weight="1" />

            </RadioGroup>

            <!-- Image Picker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile Image"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/textMedium"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:id="@+id/ivPickedImage"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_circle_border"
                    android:padding="4dp"
                    android:contentDescription="Selected Image" />

                <Button
                    android:id="@+id/btnPickImage"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Choose Image"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_primary_rounded"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

            <!-- Terms Checkbox -->
            <CheckBox
                android:id="@+id/cbAcceptTerms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accept Terms and Conditions"
                android:textColor="@color/textDark"
                android:textSize="14sp"
                android:layout_marginBottom="22dp" />

            <!-- Submit -->
            <Button
                android:id="@+id/btnSubmitForm"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Submit Registration"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:background="@drawable/btn_accent_rounded"
                android:layout_marginBottom="30dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
