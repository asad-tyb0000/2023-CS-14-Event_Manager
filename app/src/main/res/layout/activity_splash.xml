<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splashBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:paddingStart="40dp"
        android:paddingEnd="40dp">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@mipmap/ic_launcher_round"
            android:background="@drawable/circle_white_bg"
            android:padding="18dp"
            android:contentDescription="App Logo" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Smart Event Manager"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:letterSpacing="0.03"
            android:layout_marginTop="30dp" />

        <View
            android:layout_width="60dp"
            android:layout_height="3dp"
            android:background="@color/splashTextSub"
            android:layout_marginTop="14dp" />

        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to the Event Management App"
            android:textSize="15sp"
            android:textColor="@color/splashTextSub"
            android:gravity="center"
            android:layout_marginTop="14dp" />

    </LinearLayout>

</FrameLayout>
