<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pageBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Curved Hero Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="@drawable/main_hero_shape">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_centerInParent="true">

                <ImageView
                    android:id="@+id/mainLogo"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@mipmap/ic_launcher_round"
                    android:background="@drawable/icon_ring_bg"
                    android:padding="16dp"
                    android:contentDescription="App Logo" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Event Manager"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:letterSpacing="0.02"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your events, simplified."
                    android:textSize="14sp"
                    android:textColor="@color/splashTextSub"
                    android:layout_marginTop="6dp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Feature Trio Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="-28dp"
            android:clipToPadding="false">

            <!-- Feature 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/feature_circle_bg"
                    android:gravity="center"
                    android:text="\uD83C\uDF93"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seminars"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/textDark"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Feature 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/feature_circle_bg"
                    android:gravity="center"
                    android:text="\uD83D\uDEE0\uFE0F"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Workshops"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/textDark"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Feature 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:background="@drawable/feature_circle_bg"
                    android:gravity="center"
                    android:text="\uD83C\uDF10"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Webinars"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/textDark"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Description Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready to get started?"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/textDark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register for upcoming events in just a few taps. Choose from seminars, workshops, conferences, webinars, and cultural events."
                android:textSize="14sp"
                android:textColor="@color/textMedium"
                android:lineSpacingExtra="5dp"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <!-- CTA Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnRegisterEvent"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Register for Event"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:background="@drawable/btn_primary_rounded" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap above to begin your registration"
                android:textSize="12sp"
                android:textColor="@color/textLight"
                android:layout_marginTop="12dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
